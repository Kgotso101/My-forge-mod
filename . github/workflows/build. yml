name: Build Mod

on:
  push:
    branches: [ "main" ]
  workflow_dispatch: {}

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Set up Gradle
        uses: gradle/actions/setup-gradle@v3
        with:
          gradle-version: '8.1.1'

      - name: Unzip project if uploaded as a zip
        run: |
          if [ -f kcdcombat.zip ]; then
            unzip -o kcdcombat.zip -d extracted
            cp -rn extracted/kcdcombat/. .
          fi

      - name: Build mod jar
        run: gradle build --no-daemon --stacktrace

      - name: Upload jar artifact
        uses: actions/upload-artifact@v4
        with:
          name: kcdcombat-jar
          path: build/libs/*.jar
